{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "webkor/slider",
	"version": "0.2.0",
	"title": "Slider",
	"category": "widgets",
	"icon": "images-alt",
	"description": "Responsive slider with pagination, navigation, autoplay, and loop options.",
	"example": {},
	"supports": {
		"html": false,
		"align": [ "full", "wide" ]
	},
	"attributes": {
		"slides": {
			"type": "array",
			"default": [
				{
					"id": "slide-1",
					"content": "Slide 1",
					"imageId": 0,
					"imageUrl": "",
					"imageAlt": ""
				},
				{
					"id": "slide-2",
					"content": "Slide 2",
					"imageId": 0,
					"imageUrl": "",
					"imageAlt": ""
				}
			]
		},
		"spaceBetween": {
			"type": "number",
			"default": 10
		},
		"slidesPerView": {
			"type": "number",
			"default": 1
		},
		"slidesPerViewTablet": {
			"type": "number",
			"default": 0
		},
		"slidesPerViewMobile": {
			"type": "number",
			"default": 0
		},
		"enablePagination": {
			"type": "boolean",
			"default": true
		},
		"paginationType": {
			"type": "string",
			"default": "bullets"
		},
		"paginationColor": {
			"type": "string",
			"default": "#999999"
		},
		"paginationActiveColor": {
			"type": "string",
			"default": "#333333"
		},
		"enableNavigation": {
			"type": "boolean",
			"default": true
		},
		"navigationColor": {
			"type": "string",
			"default": "#333333"
		},
		"navigationSize": {
			"type": "number",
			"default": 30
		},
		"enableAutoplay": {
			"type": "boolean",
			"default": false
		},
		"autoplayDelay": {
			"type": "number",
			"default": 5000
		},
		"autoplayDisableOnInteraction": {
			"type": "boolean",
			"default": true
		},
		"loop": {
			"type": "boolean",
			"default": true
		},
		"effect": {
			"type": "string",
			"default": "slide"
		},
		"speed": {
			"type": "number",
			"default": 300
		},
		"containerWidth": {
			"type": "string",
			"default": "100%"
		},
		"containerMargin": {
			"type": "string",
			"default": "0"
		},
		"containerPadding": {
			"type": "string",
			"default": "0"
		},
		"slideHeight": {
			"type": "string",
			"default": "320px"
		},
		"heightMode": {
			"type": "string",
			"default": "fixed"
		},
		"aspectRatio": {
			"type": "string",
			"default": "16/9"
		},
		"fullWidth": {
			"type": "boolean",
			"default": false
		}
	},
	"textdomain": "slider",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}
